{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "demo-trading-apps",
  "main": "worker.js",
  "compatibility_date": "2026-05-28",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "demo.vike.io", "custom_domain": true }
  ]
}
